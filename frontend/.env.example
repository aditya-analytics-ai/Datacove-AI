# ── Datacove Frontend Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.

# Backend API base URL — leave UNSET in development so Vite's proxy routes
# /api requests to localhost:8000 automatically (see vite.config.js).
# Only set this for production builds pointing at a deployed backend.
# VITE_API_URL=https://your-production-api.example.com/api
