# ─────────────────────────────────────────────────────────────────────────────
# Datacove .env.example
# Copy to .env and fill in your values.
# Lines starting with # are comments.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Auth on/off (True = required, False = disable for local dev only)
AUTH_ENABLED=True

# CORS — comma-separated list of allowed frontend origins (no wildcards with AUTH_ENABLED=True)
CORS_ORIGINS=http://localhost:5173

# Frontend URL (included in password-reset email links)
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_URL=mysql://datacove_user:yourpassword@localhost:3306/datacove

# ── Redis (optional — enables Celery job queue + multi-worker session store) ──
# Leave blank to use in-process ThreadPoolExecutor + in-memory sessions
REDIS_URL=redis://localhost:6379/0

# ── SMTP email (optional — enables real password reset emails) ────────────────
# Leave blank to return reset token in API response (dev/self-hosted mode)

# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx    # 16-char Google App Password
# SMTP_FROM=you@gmail.com
# SMTP_TLS=true

# SendGrid example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=noreply@yourapp.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@datacove.ai
SMTP_TLS=true

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Stripe (optional — billing) ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Rate limiting (optional overrides) ───────────────────────────────────────
# API_RATE_LIMIT_GLOBAL=300      # requests per window (default 300)
# API_RATE_LIMIT_UPLOAD=10       # requests per window for /upload,/connectors

# ── Tuning ────────────────────────────────────────────────────────────────────
# MAX_UPLOAD_BYTES=52428800      # 50 MB default
# SESSION_TTL_SECONDS=3600       # 1 hour default
# SESSION_MAX_COUNT=200          # max in-memory sessions
